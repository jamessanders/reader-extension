{
  "manifest_version": 2,
  "name": "Read Aloud",
  "version": "4.0.0",
  "description": "Read webpage text aloud using Edge TTS or a local Kokoro service, with sentence highlighting.",
  "icons": {
    "48": "icons/icon-48.svg",
    "96": "icons/icon-96.svg"
  },
  "permissions": [
    "activeTab",
    "storage",
    "webRequest",
    "webRequestBlocking",
    "*://speech.platform.bing.com/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "content_security_policy": "script-src 'self'; object-src 'self'",
  "browser_action": {
    "default_icon": "icons/icon-48.svg",
    "default_popup": "popup/popup.html",
    "default_title": "Read Aloud"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["browser-compat.js", "content/reader.js"],
      "css": ["content/reader.css"]
    }
  ],
  "background": {
    "page": "background/background.html"
  }
}
